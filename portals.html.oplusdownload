<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="البوابات العلمية — مركز موهبتي مستقبلي: 15 بوابة متخصصة في أنواع الذكاء والمواهب مع كويز تفاعلي لكل بوابة — ولاية المدية، الجزائر">
<meta name="keywords" content="بوابات علمية, أنواع الذكاء, غاردنر, رنزولي, موهبة, كويز">
<meta name="theme-color" content="#6366f1">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="موهبتي">
<link rel="manifest" href="manifest.json">
<title>البوابات العلمية — موهبتي مستقبلي | ولاية المدية، الجزائر</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased;}
:root{
  /* ── Primary: Modern Indigo ── */
  --primary-50:#eef2ff;--primary-100:#e0e7ff;--primary-200:#c7d2fe;--primary-300:#a5b4fc;
  --primary-400:#818cf8;--primary-500:#6366f1;--primary-600:#4f46e5;--primary-700:#4338ca;
  /* ── Accent: Soft Cyan ── */
  --cyan-400:#22d3ee;--cyan-500:#06b6d4;--cyan-600:#0891b2;
  /* ── Accent: Soft Purple ── */
  --purple-400:#a78bfa;--purple-500:#8b5cf6;--purple-600:#7c3aed;
  /* ── Dark Mode: Deep Navy ── */
  --ink:#0f172a;--ink2:#1e293b;--ink3:#27354f;--ink4:#334155;
  /* ── Brand: Indigo Gold Replacement ── */
  --gold:#6366f1;--gold-l:#818cf8;--gold-xl:#a5b4fc;
  --gold-dim:rgba(99,102,241,0.07);--gold-glow:rgba(99,102,241,0.22);--gold-border:rgba(99,102,241,0.28);
  /* ── Text ── */
  --text:#f1f5f9;--text-soft:#cbd5e1;--text-muted:#64748b;--border:rgba(148,163,184,0.08);
  /* ── Semantic Colors ── */
  --teal:#06b6d4;--purple:#8b5cf6;--amber:#f59e0b;--rose:#f43f5e;
  --cyan:#22d3ee;--green:#10b981;--crimson:#ef4444;--sport:#3b82f6;
  --leader:#a855f7;--visual:#f97316;--ling:#eab308;--math:#22c55e;
  --nature:#34d399;--social:#8b5cf6;
  /* ── Spacing & Effects ── */
  --r:12px;--r-lg:16px;--r-xl:24px;
  --ease:cubic-bezier(0.4,0,0.2,1);--spring:cubic-bezier(0.34,1.56,0.64,1);
  /* ── Glassmorphism ── */
  --glass-bg:rgba(30,41,59,0.6);--glass-border:rgba(148,163,184,0.1);
  --glass-blur:blur(24px) saturate(1.4);
  /* ── Shadows ── */
  --shadow-sm:0 1px 2px rgba(0,0,0,0.3);--shadow-md:0 4px 16px rgba(0,0,0,0.3);
  --shadow-lg:0 8px 32px rgba(0,0,0,0.35);--shadow-xl:0 16px 48px rgba(0,0,0,0.4);
  --shadow-glow:0 0 40px rgba(99,102,241,0.12);
}
body{font-family:'IBM Plex Sans Arabic',sans-serif;background:var(--ink);color:var(--text);overflow-x:hidden;direction:rtl;line-height:1.6;transition:background 0.5s var(--ease),color 0.5s var(--ease);}
h1,h2,h3,h4,h5{font-family:'Tajawal',sans-serif;line-height:1.2;}
a{color:inherit;text-decoration:none;}
button{font-family:inherit;cursor:pointer;border:none;background:none;}
img{max-width:100%;display:block;}
::selection{background:var(--gold-dim);color:var(--gold-l);}
::-webkit-scrollbar{width:5px;}
::-webkit-scrollbar-track{background:var(--ink2);}
::-webkit-scrollbar-thumb{background:var(--ink4);border-radius:99px;}
::-webkit-scrollbar-thumb:hover{background:var(--primary-500);}

/* NOISE */
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");opacity:0.35;mix-blend-mode:overlay;}

/* ══ SCROLL PROGRESS ══ */
#scrollBar{position:fixed;top:0;right:0;left:0;height:2px;background:linear-gradient(90deg,var(--gold),var(--cyan-500));z-index:9999;transform-origin:right;transform:scaleX(0);transition:transform 0.1s linear;}

/* ══ AMBIENT ORBS ══ */
.amb-orb{position:fixed;border-radius:50%;pointer-events:none;z-index:0;filter:blur(80px);opacity:0.13;animation:aOrbDrift 20s ease-in-out infinite alternate;}
.amb-orb1{width:500px;height:500px;background:radial-gradient(circle,rgba(201,168,76,0.65),transparent 70%);top:-200px;right:-100px;}
.amb-orb2{width:400px;height:400px;background:radial-gradient(circle,rgba(0,201,177,0.5),transparent 70%);bottom:-150px;left:-80px;animation-delay:-9s;}
@keyframes aOrbDrift{0%{transform:translate(0,0);}50%{transform:translate(32px,-26px);}100%{transform:translate(-18px,38px);}}

/* ══ CURSOR ══ */
#mmCursor,#mmRing{position:fixed;border-radius:50%;pointer-events:none;z-index:99998;}
#mmCursor{width:11px;height:11px;background:var(--gold);transform:translate(-50%,-50%);transition:width .3s,height .3s,background .3s;mix-blend-mode:exclusion;}
#mmRing{width:38px;height:38px;border:1px solid var(--gold-border);transform:translate(-50%,-50%);transition:width .3s,height .3s,border-color .3s;}

/* ══ LOADER ══ */
#ptLoader{position:fixed;inset:0;background:var(--ink);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:99999;gap:20px;}
#ptLoader.out{animation:ptLOut 0.7s ease forwards;}
@keyframes ptLOut{to{opacity:0;visibility:hidden;pointer-events:none;}}
.ptl-diamond{width:56px;height:56px;position:relative;animation:ptLSpin 4s linear infinite;}
.ptl-diamond::before,.ptl-diamond::after{content:'';position:absolute;inset:0;border:1.5px solid var(--gold);animation:ptLPulse 2s ease-in-out infinite;}
.ptl-diamond::after{inset:10px;border-color:var(--gold-border);animation-delay:.5s;}
.ptl-title{font-family:'Tajawal',sans-serif;font-size:22px;font-weight:900;color:var(--gold);letter-spacing:5px;animation:ptLPulse 2s ease-in-out infinite;}
.ptl-sub{font-size:9px;color:var(--text-muted);letter-spacing:3px;text-transform:uppercase;}
.ptl-bar{width:120px;height:1px;background:var(--ink4);position:relative;overflow:hidden;}
.ptl-bar::after{content:'';position:absolute;top:0;right:0;height:100%;width:0;background:linear-gradient(90deg,transparent,var(--gold),transparent);animation:ptLLine 2.2s ease .3s forwards;}
@keyframes ptLSpin{to{transform:rotate(360deg);}}
@keyframes ptLPulse{0%,100%{opacity:.3;}50%{opacity:1;}}
@keyframes ptLLine{to{width:100%;}}

/* ══ PARTICLE CANVAS ══ */
#ptParticles{position:fixed;inset:0;z-index:1;pointer-events:none;}

/* ══ ENHANCED CARDS ══ */
.portal-card{box-shadow:0 4px 20px rgba(0,0,0,0.22);}
.portal-card:hover{box-shadow:0 24px 56px rgba(0,0,0,0.55),0 0 0 1px var(--pc-accent,rgba(201,168,76,0.3));}
.modal{box-shadow:0 40px 100px rgba(0,0,0,0.8);}

/* ══ HERO ANIMATIONS ══ */
.hero-eyebrow{animation:fadeUpP .8s ease both;}
.hero-title{animation:fadeUpP .9s ease .1s both;}
.hero-desc{animation:fadeUpP 1s ease .2s both;}
.hero-stats{animation:fadeUpP 1.1s ease .3s both;}
@keyframes fadeUpP{from{opacity:0;transform:translateY(28px);}to{opacity:1;transform:translateY(0);}}

/* NAVBAR */
.nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:14px 0;background:var(--glass-bg);backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur);border-bottom:1px solid var(--glass-border);transition:all 0.3s;transition:all 0.3s;}
.nav-wrap{max-width:1280px;margin:0 auto;padding:0 28px;display:flex;align-items:center;justify-content:space-between;}
.nav-brand{display:flex;align-items:center;gap:10px;text-decoration:none;}
.nav-mark{width:32px;height:32px;border:1.5px solid var(--gold);display:flex;align-items:center;justify-content:center;position:relative;}
.nav-mark::before{display:none;}
.nav-mark svg{width:11px;height:11px;color:var(--gold);}
.nav-name{font-family:'Tajawal',sans-serif;font-size:17px;font-weight:900;color:var(--text);}
.nav-name span{color:var(--gold);}
.nav-acts{display:flex;gap:10px;align-items:center;}
.btn{display:inline-flex;align-items:center;gap:7px;padding:8px 18px;border-radius:var(--r);font-size:13px;font-weight:600;transition:all 0.3s;white-space:nowrap;}
.btn-primary{background:linear-gradient(135deg,var(--primary-600),var(--primary-500));color:#fff;box-shadow:0 4px 20px rgba(99,102,241,0.28);}
.btn-primary:hover{background:linear-gradient(135deg,var(--primary-500),var(--primary-400));transform:translateY(-1px);box-shadow:0 8px 32px rgba(99,102,241,0.35);}
.btn-secondary{background:transparent;color:var(--text-soft);border:1px solid var(--ink4);}
.btn-secondary:hover{border-color:var(--gold-border);color:var(--text);background:var(--gold-dim);}
.btn-sm{padding:6px 14px;font-size:12px;}

/* HERO */
.hero{min-height:100vh;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden;padding-top:80px;}
.hero-video-panel{position:absolute;inset:0;z-index:1;}
.hero-video-panel::after{content:'';position:absolute;inset:0;z-index:1;background:rgba(10,15,30,0.5);}
#portalsVideo{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;filter:brightness(0.7) saturate(1.1);}
body.light #portalsVideo{filter:brightness(0.85) saturate(0.9);}
.hero-bg{display:none;}
.hero-grid{position:absolute;inset:0;z-index:2;background-image:linear-gradient(rgba(99,102,241,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(99,102,241,0.025) 1px,transparent 1px);background-size:60px 60px;}
.hero-content{position:relative;z-index:10;max-width:700px;margin:0 auto;padding:48px 40px;text-align:center;width:100%;background:rgba(15,23,42,0.55);backdrop-filter:blur(20px) saturate(1.4);-webkit-backdrop-filter:blur(20px) saturate(1.4);border:1px solid rgba(148,163,184,0.1);border-radius:24px;box-shadow:0 8px 32px rgba(0,0,0,0.35);}
body.light .hero-content{background:rgba(255,255,255,0.55);}
.hero-eyebrow{display:inline-flex;align-items:center;gap:9px;padding:5px 16px;border-radius:99px;border:1px solid var(--gold-border);background:var(--gold-dim);margin-bottom:24px;}
.eyebrow-dot{width:7px;height:7px;border-radius:50%;background:var(--gold);animation:blink 2s infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.3;}}
.eyebrow-txt{font-size:11px;font-weight:700;color:var(--gold-l);letter-spacing:1.5px;text-transform:uppercase;}
.hero-title{font-size:clamp(34px,5vw,64px);font-weight:900;line-height:1.1;margin-bottom:18px;}
.hero-title .hl{background:linear-gradient(135deg,var(--primary-500),var(--cyan-400),var(--purple-400));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hero-desc{font-size:16px;color:var(--text-soft);line-height:1.9;max-width:580px;margin:0 auto 32px;font-weight:300;}
.hero-stats{display:flex;align-items:center;justify-content:center;gap:32px;flex-wrap:wrap;}
.h-stat{text-align:center;}
.h-stat-num{font-family:'Tajawal',sans-serif;font-size:30px;font-weight:900;color:var(--gold);line-height:1;}
.h-stat-lbl{font-size:11px;color:var(--text-muted);margin-top:3px;}
.h-div{width:1px;height:32px;background:var(--ink4);}

/* PORTAL FILTER BAR */
.filter-bar{background:var(--ink2);border-bottom:1px solid var(--border);backdrop-filter:blur(12px) saturate(1.1);-webkit-backdrop-filter:blur(12px) saturate(1.1);position:sticky;top:61px;z-index:150;overflow-x:auto;}
.filter-inner{max-width:1280px;margin:0 auto;padding:0 28px;display:flex;gap:6px;padding-top:14px;padding-bottom:14px;align-items:center;}
.filter-btn{
  padding:7px 18px;border-radius:99px;font-size:12px;font-weight:600;
  border:1px solid var(--border);background:transparent;color:var(--text-muted);
  transition:all 0.2s;white-space:nowrap;cursor:pointer;flex-shrink:0;
}
.filter-btn:hover{border-color:var(--gold-border);color:var(--text);}
.filter-btn.active{background:var(--gold-dim);border-color:var(--gold-border);color:var(--gold-l);}

/* PORTALS GRID */
.portals-section{padding:60px 0;}
.wrap{max-width:1280px;margin:0 auto;padding:0 28px;}
.portals-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;}

/* PORTAL CARD */
.portal-card{
  border-radius:var(--r-xl);border:1px solid var(--ink4);background:var(--ink2);
  overflow:hidden;transition:all 0.4s var(--spring);cursor:pointer;
  position:relative;
}
.portal-card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 80% 20%,var(--pc-glow,transparent) 0%,transparent 60%);opacity:0;transition:opacity 0.3s;}
.portal-card:hover{transform:translateY(-8px);border-color:var(--pc-accent,var(--gold-border));box-shadow:0 20px 48px rgba(0,0,0,0.5);}
.portal-card:hover::before{opacity:1;}
